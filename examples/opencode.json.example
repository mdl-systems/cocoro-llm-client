# opencode.json example

```json
{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM",
      "options": {
        "baseURL": "http://YOUR_SERVER_IP:4000/v1",
        "apiKey": "your_api_key_here"
      },
      "models": {
        "coco-local": {
          "name": "Coco Local (vLLM, multimodal)",
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "claude-sonnet": {
          "name": "Claude Sonnet",
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        }
      }
    }
  },
  "model": "litellm/coco-local",
  "agent": {
    "chat": {
      "description": "設計・要約・相談用 (LiteLLM経由)",
      "model": "litellm/coco-local",
      "prompt": "You are a helpful assistant.",
      "tools": {
        "read": true,
        "write": false,
        "edit": false,
        "bash": false,
        "webfetch": true
      }
    },
    "build": {
      "description": "実装・コーディング用 (LiteLLM経由)",
      "model": "litellm/coco-local",
      "prompt": "You are a coding assistant that writes and edits code.",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true,
        "webfetch": true
      }
    }
  }
}
```
