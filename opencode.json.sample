{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM",
      "options": {
        "baseURL": "http://YOUR_SERVER_IP:4000/v1",
        "apiKey": "YOUR_API_KEY_HERE"
      },
      "models": {
        "qwen3-coder": {
          "name": "Qwen3 Coder"
        },
        "smart-coder": {
          "name": "Smart Coder (Local + Claude Fallback)"
        },
        "claude-sonnet": {
          "name": "Claude Sonnet"
        }
      }
    }
  },
  "model": "litellm/qwen3-coder",
  "agent": {
    "chat": {
      "description": "設計・要約・相談用 (LiteLLM経由)",
      "model": "litellm/qwen3-coder",
      "prompt": "You are a helpful assistant.",
      "tools": {
        "read": true,
        "write": false,
        "edit": false,
        "bash": false,
        "webfetch": false
      }
    },
    "build": {
      "description": "実装・コーディング用 (LiteLLM経由)",
      "model": "litellm/qwen3-coder",
      "prompt": "You are a coding assistant that writes and edits code.",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true,
        "webfetch": false
      }
    }
  }
}
